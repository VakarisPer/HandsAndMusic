            <Array as="points">
              <mxPoint x="420" y="550" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="ea3j" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;"
                edge="1" parent="1" source="app" target="fac">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="ea3k" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;"
