<mxfile host="app.diagrams.net">
  <diagram name="Runtime Flow" id="p2">
    <mxGraphModel dx="900" dy="1400" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="1"
                  pageScale="1" pageWidth="900" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t2" value="&lt;b&gt;&lt;font size=&quot;18&quot;&gt;Hands &amp;amp; Music — Runtime Flow&lt;/font&gt;&lt;/b&gt;"
                style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;"
                vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="500" height="35" as="geometry" />
        </mxCell>

        <!-- Start -->
        <mxCell id="s0" value="&lt;b&gt;Program Start&lt;/b&gt;&#10;python main.py"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;"
                vertex="1" parent="1">
          <mxGeometry x="340" y="55" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- Init -->
        <mxCell id="s1" value="&lt;b&gt;Initialize&lt;/b&gt;&#10;pygame.init() · GameConfig()&#10;ScoreManager(&quot;scores.json&quot;)"
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;"
                vertex="1" parent="1">
          <mxGeometry x="320" y="140" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- Menu -->
        <mxCell id="s2" value="&lt;b&gt;run_menu()&lt;/b&gt;&#10;Menu Loop&#10;Camera Feed Background&#10;Rainbow Title · Gesture Navigation&#10;Leaderboard (Top 10)"
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;"
                vertex="1" parent="1">
          <mxGeometry x="310" y="240" width="260" height="75" as="geometry" />
        </mxCell>

        <!-- Decision -->
        <mxCell id="s3" value="User&#10;Action?"
                style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;"
                vertex="1" parent="1">
          <mxGeometry x="360" y="355" width="160" height="100" as="geometry" />
        </mxCell>

        <!-- Settings -->
        <mxCell id="s4" value="&lt;b&gt;Settings&lt;/b&gt;&#10;Volume · Username&#10;Browse Audio · Select Level&#10;Record New Level"
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;"
                vertex="1" parent="1">
          <mxGeometry x="50" y="355" width="190" height="85" as="geometry" />
        </mxCell>

        <!-- Exit -->
        <mxCell id="s5" value="&lt;b&gt;Exit&lt;/b&gt;&#10;pygame.quit()"
