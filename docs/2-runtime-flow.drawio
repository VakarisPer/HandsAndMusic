                vertex="1" parent="1">
          <mxGeometry x="600" y="880" width="155" height="50" as="geometry" />
        </mxCell>

        <!-- Results -->
        <mxCell id="s9" value="&lt;b&gt;Game Over · Save Score&lt;/b&gt;&#10;score_manager.add_score()&#10;scores.json (Top 10)"
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;"
                vertex="1" parent="1">
          <mxGeometry x="310" y="1020" width="260" height="60" as="geometry" />
        </mxCell>

        <!-- Back to Menu -->
        <mxCell id="s10" value="&lt;b&gt;Return to Menu&lt;/b&gt;&#10;Loop Forever"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;"
                vertex="1" parent="1">
          <mxGeometry x="340" y="1120" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- EDGES -->
        <mxCell id="ea2a" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;"
