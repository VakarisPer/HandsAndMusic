          <mxGeometry x="320" y="585" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- GameApp.run() -->
        <mxCell id="s8" value="&lt;b&gt;GameApp.run(username)&lt;/b&gt;&#10;AudioClock.start()&#10;Main Game Loop @ 120 FPS"
