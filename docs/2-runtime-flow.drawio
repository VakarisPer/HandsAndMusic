          <mxGeometry x="320" y="685" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- Game Loop Detail -->
        <mxCell id="glc" value="&lt;b&gt;Game Loop — Per Frame&lt;/b&gt;"
