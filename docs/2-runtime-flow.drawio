                vertex="1" parent="1">
          <mxGeometry x="260" y="880" width="155" height="45" as="geometry" />
        </mxCell>

        <mxCell id="gl7" value="7. Gesture → Lane&#10;Fist→L0 Palm→L1&#10;Point→L2 Thumb→L3 V→L4"
