                vertex="1" parent="1">
          <mxGeometry x="640" y="370" width="120" height="55" as="geometry" />
        </mxCell>

        <!-- Play -->
        <mxCell id="s6" value="&lt;b&gt;Play Selected&lt;/b&gt;"
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;"
                vertex="1" parent="1">
          <mxGeometry x="365" y="500" width="150" height="45" as="geometry" />
